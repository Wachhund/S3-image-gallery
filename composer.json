{
    "name": "s3gallery/s3-image-gallery",
    "description": "Modern PHP image gallery with S3-compatible storage (RustFS)",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "aws/aws-sdk-php": "^3.300",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.4",
        "slim/php-view": "^3.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "S3Gallery\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "S3Gallery\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src --level=6",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
