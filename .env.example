# S3 Image Gallery - Environment Configuration
# Copy to .env and adjust values: cp .env.example .env

# --- PHP ---
PHP_VERSION=8.5

# --- Database (MariaDB) ---
DB_HOST=db
DB_PORT=3306
DB_NAME=s3gallery
DB_USER=s3gallery
DB_PASSWORD=changeme

# --- S3 Storage (RustFS) ---
S3_ENDPOINT=http://storage:9000
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
S3_BUCKET=gallery
S3_REGION=us-east-1

# --- Ports (Host) ---
NGINX_PORT=8080
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001

# --- Application ---
APP_DEBUG=true

# --- Auth ---
S3G_REGISTRATION_OTP=
S3G_RP_ID=localhost
